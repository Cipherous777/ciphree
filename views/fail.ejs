<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>Connection Error | Ciphree</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Clash Display', sans-serif; }
    body { background-color: #050505; }
    .bg-fail-mesh {
      background: radial-gradient(circle at center, #2d0606 0%, #050505 100%);
    }
    .glass-card {
      background: rgba(255, 255, 255, 0.02);
      backdrop-filter: blur(40px);
      border: 1px solid rgba(244, 63, 94, 0.2);
    }
    .fade-up { animation: fadeUp 1s ease-out forwards; }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body class="text-white overflow-hidden bg-fail-mesh">
  <div class="relative min-h-screen flex items-center justify-center px-6">
    <main class="max-w-xl w-full text-center z-10 fade-up">
      <div class="glass-card p-12 md:p-20 rounded-[60px] shadow-2xl border-rose-500/20">
        <div class="mb-8 flex justify-center">
          <div class="w-20 h-20 rounded-full bg-rose-500/10 text-rose-400 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">Something is wrong!</h1>
        <p class="text-gray-400 text-lg mb-10 leading-relaxed">
          We encountered an error while processing your request. The transmission was interrupted before it reached our servers.
        </p>
        <div class="flex flex-col gap-4">
          <a href="javascript:history.back()" class="bg-white text-black hover:bg-gray-200 px-10 py-4 rounded-full font-bold transition-all">
            Try again brother
          </a>
          <a href="/" class="text-gray-500 hover:text-white text-sm transition-colors">Return to HQ</a>
        </div>
      </div>
    </main>
  </div>
</body>
</html>