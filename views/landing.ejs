<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <link href="https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/694431590807b62fc30f1c38/82ce8b60c_image.png" rel="icon" type="image/svg+xml">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  
  <title><%= typeof title !== 'undefined' ? title : 'Ciphree | Augmented Intelligence & Emotional Connection' %></title>
  <meta name="description" content="Ciphree is an augmented intelligence company building emotionally intelligent systems. Discover Moments, our minimal app for authentic emotional expression.">
  <meta name="keywords" content="Ciphree, Moments app, Augmented Intelligence, Emotional AI, human connection, mindful tech">
  <meta property="og:title" content="Ciphree | Intelligence That Feels Human">
  <meta property="og:description" content="Express, reflect, and understand emotions through AI-driven resonance. Explore the Ciphree ecosystem.">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  
  <link href="https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/694431590807b62fc30f1c38/82ce8b60c_image.png" rel="manifest">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap" rel="stylesheet">
  
  <style>
    * { font-family: 'Clash Display', sans-serif; }
    html { scroll-behavior: smooth; }
    .fade-in { opacity: 0; transform: translateY(40px); transition: opacity 0.8s ease-out, transform 0.8s ease-out; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }
    .hero-title span { display: inline-block; opacity: 0; transform: translateY(30px); animation: fadeUp 0.8s forwards ease-out; }
    .hero-title span:nth-child(1) { animation-delay: 0.2s; }
    .hero-title span:nth-child(2) { animation-delay: 0.4s; }
    .hero-title span:nth-child(3) { animation-delay: 0.6s; }
    .hero-title span:nth-child(4) { animation-delay: 0.8s; }
    .hero-title span:nth-child(5) { animation-delay: 1.0s; }
    .hero-title span:nth-child(6) { animation-delay: 1.2s; }
    .hero-title span:nth-child(7) { animation-delay: 1.4s; }
    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
    .feature-card { transition: transform 0.4s ease, box-shadow 0.4s ease; }
    .feature-card:hover { transform: translateY(-12px); box-shadow: 0 24px 48px rgba(0,0,0,0.15); }
    .pulse-btn { animation: pulse 2.5s infinite; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(28, 115, 228, 0.4); } 70% { box-shadow: 0 0 0 14px rgba(28, 115, 228, 0); } 100% { box-shadow: 0 0 0 0 rgba(28, 115, 228, 0); } }
    .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.5s ease, padding 0.5s ease; }
    .faq-content.open { max-height: 500px; padding: 16px 0; }
    .rotate-icon { transition: transform 0.3s ease; }
    .typing-wrapper { display: inline-block; overflow: hidden; white-space: nowrap; border-right: 3px solid #1C73E4; width: 0; }
    .typing-wrapper.animate { animation: typing 4s steps(70) forwards, blink 0.75s step-end infinite; }
    @keyframes typing { from { width: 0 } to { width: 100% } }
    @keyframes blink { from, to { border-color: transparent } 50% { border-color: #1C73E4; } }
  </style>
</head>
<body class="bg-white">
  <div class="min-h-screen bg-white">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
      <div class="mx-auto max-w-7xl px-6 py-4">
        <div class="flex items-center justify-between relative">
          <a class="flex items-center gap-2 z-10" href="/" aria-label="Ciphree Home">
            <img src="https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/694431590807b62fc30f1c38/82ce8b60c_image.png" alt="Ciphree Logo" class="w-10 h-10">
            <span class="text-xl font-bold text-gray-900">Ciphree</span>
          </a>
          <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 items-center gap-1 bg-[#1C73E4] rounded-full p-1">
            <a href="#home" class="nav-link px-4 py-2 text-white hover:bg-white/20 rounded-full text-sm font-medium transition-colors">Home</a>
            <a href="#features" class="nav-link px-4 py-2 text-white hover:bg-white/20 rounded-full text-sm font-medium transition-colors">Moments</a>
            <a href="#faq" class="nav-link px-4 py-2 text-white hover:bg-white/20 rounded-full text-sm font-medium transition-colors">FAQ</a>
            <a href="#about" class="nav-link px-4 py-2 text-white hover:bg-white/20 rounded-full text-sm font-medium transition-colors">Mission</a>
            <a href="#contact" class="nav-link px-4 py-2 text-white hover:bg-white/20 rounded-full text-sm font-medium transition-colors">Contact</a>
          </div>
          <a href="/moments" class="hidden md:block z-10"><button class="bg-[#1C73E4] hover:bg-[#1557b8] text-white px-6 py-2 rounded-full text-sm font-medium transition-colors">Explore Moments</button></a>
          <button id="mobile-menu-btn" class="md:hidden z-10" aria-label="Open Menu">
            <svg class="h-8 w-8 text-gray-900" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
        <div id="mobile-menu" class="md:hidden hidden mt-4 rounded-2xl p-4 space-y-2 bg-white shadow-xl border border-gray-100">
  <a href="#home" class="nav-link block px-4 py-3 text-gray-900 hover:bg-gray-50 rounded-xl font-medium transition-colors">Home</a>
  <a href="#features" class="nav-link block px-4 py-3 text-gray-900 hover:bg-gray-50 rounded-xl font-medium transition-colors">Moments</a>
  <a href="#faq" class="nav-link block px-4 py-3 text-gray-900 hover:bg-gray-50 rounded-xl font-medium transition-colors">FAQ</a>
  <a href="#about" class="nav-link block px-4 py-3 text-gray-900 hover:bg-gray-50 rounded-xl font-medium transition-colors">Mission</a>
  <a href="#contact" class="nav-link block px-4 py-3 text-gray-900 hover:bg-gray-50 rounded-xl font-medium transition-colors">Contact</a>
  
  <div class="pt-4 border-t border-gray-100">
    <a href="/moments" class="block w-full bg-[#1C73E4] text-white py-4 rounded-xl font-bold text-center shadow-lg active:scale-95 transition-transform">
      Explore Moments
    </a>
  </div>
</div>
      </div>
    </nav>

    <main class="pt-20">
      <section id="home" class="relative bg-black text-white min-h-[700px] flex items-center overflow-hidden">
        <div class="absolute inset-0">
          <img src="https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/694431590807b62fc30f1c38/a5c4896f6_image.png" alt="Emotional Intelligence Background" class="w-full h-full object-cover opacity-40">
          <div class="absolute inset-0 bg-gradient-to-b from-black via-transparent to-black/60"></div>
        </div>
        <div class="relative w-full px-6 py-20">
          <div class="max-w-4xl mx-auto text-center fade-in">
            <h1 class="text-5xl md:text-7xl font-bold mb-8 leading-tight hero-title">
              <span>Building</span> <span>Intelligence</span> <span>That</span> <span class="text-[#1C73E4]">Feels</span> <span>Human.</span>
            </h1>
            <p class="text-xl md:text-2xl text-gray-300 mb-10 max-w-2xl mx-auto leading-relaxed">
              Ciphree is an augmented intelligence company. We help people express, reflect, and understand emotions through high-fidelity AI systems.
            </p>
            <div class="flex flex-col md:flex-row gap-4 justify-center">
              <a href="/moments"><button class="shadow bg-[#1C73E4] hover:bg-[#1557b8] text-white px-10 py-6 text-lg rounded-full pulse-btn font-semibold">Explore Moments</button></a>
              <a href="#about" class="border border-white/30 bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white px-10 py-6 text-lg rounded-full transition-all">Our Mission</a>
            </div>
          </div>
        </div>
      </section>

      <section id="features" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-16 fade-in">
            <h2 class="text-sm font-bold text-[#1C73E4] tracking-[0.2em] uppercase mb-4">First Launch</h2>
            <h3 class="text-5xl font-bold text-gray-900 mb-6">Moments by Ciphree</h3>
            <p class="text-gray-600 text-xl max-w-2xl mx-auto">A minimal app designed to replace algorithmic noise with meaningful emotional resonance.</p>
          </div>
          <div class="grid md:grid-cols-3 gap-8 mb-12">
            <div class="bg-white rounded-3xl border-2 border-gray-100 p-8 feature-card fade-in">
              <div class="text-5xl mb-6" aria-hidden="true">✨</div>
              <h3 class="text-xl font-bold text-gray-900 mb-4">Resonance Matching</h3>
              <p class="text-gray-600 leading-relaxed">Skip the superficial bios. Connect with others based on shared emotional frequency and current perspective.</p>
            </div>
            <div class="bg-white rounded-3xl border-2 border-gray-100 p-8 feature-card fade-in">
              <div class="text-5xl mb-6" aria-hidden="true">🌀</div>
              <h3 class="text-xl font-bold text-gray-900 mb-4">Emotional Reflection</h3>
              <p class="text-gray-600 leading-relaxed">A mindful space to log "moments"—brief, honest expressions of your state, free from the pressure of likes.</p>
            </div>
            <div class="bg-white rounded-3xl border-2 border-gray-100 p-8 feature-card fade-in">
              <div class="text-5xl mb-6" aria-hidden="true">🌿</div>
              <h3 class="text-xl font-bold text-gray-900 mb-4">Focus & Clarity</h3>
              <p class="text-gray-600 leading-relaxed">A distraction-free environment. No endless scrolling—just pure, intentional human connection.</p>
            </div>
          </div>
          <div class="text-center fade-in">
            <p class="text-gray-500 font-medium text-lg mb-8">Zero-Ad Policy • Privacy-Preserving AI • Authentic Expression</p>
            <a href="#contact" class="inline-block shadow bg-[#1C73E4] hover:bg-[#1557b8] text-white px-8 py-4 text-lg rounded-full font-medium transition-all">Get Early Access to Moments</a>
          </div>
        </div>
      </section>

      <section id="faq" class="py-20 bg-gray-50">
        <div class="max-w-4xl mx-auto px-6">
          <div class="text-center mb-16 fade-in">
            <h2 class="text-4xl md:text-5xl font-bold text-[#1C73E4] mb-4">Understanding Ciphree</h2>
          </div>
          <div class="space-y-4">
            <% const faqs = [
              { q: 'What is "Augmented Intelligence"?', a: 'We don\'t replace human intelligence; we augment it. Our systems enhance your emotional clarity, using AI to bridge communication gaps often created by traditional tech.' },
              { q: 'How does the AI handle my emotions?', a: 'We use proprietary emotional modeling to understand nuance. This data is used exclusively to help you reflect or find resonance—never for targeted advertising.' },
              { q: 'Is "Moments" a social network?', a: '"Moments" is an anti-social platform. It removes the competitive nature of followers and feeds, focusing entirely on shared vulnerability and presence.' }
            ]; %>
            <% faqs.forEach((faq, index) => { %>
              <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden fade-in">
                <button class="accordion-toggle w-full px-6 py-5 flex items-center justify-between text-left hover:bg-gray-50 transition-colors">
                  <span class="text-lg font-semibold text-gray-900 pr-4"><%= faq.q %></span>
                  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-[#1C73E4] flex items-center justify-center rotate-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-white">
                      <path d="M5 12h14"></path>
                      <path d="M12 5v14"></path>
                    </svg>
                  </div>
                </button>
                <div class="faq-content px-6 text-gray-600">
                  <p class="p-6"><%= faq.a %></p>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      </section>

      <section id="about" class="py-20 bg-white">
        <div class="max-w-6xl mx-auto px-6">
          <div class="text-center mb-16 fade-in">
            <h2 class="text-5xl font-bold text-[#1C73E4] mb-6">Our Mission</h2>
          </div>
          <div class="grid md:grid-cols-3 gap-8 mb-16">
            <div class="text-center fade-in">
              <div class="text-2xl font-bold text-gray-900 mb-2">2026</div>
              <div class="text-gray-600">Future-Ready</div>
            </div>
            <div class="text-center fade-in">
              <div class="text-2xl font-bold text-gray-900 mb-2">100%</div>
              <div class="text-gray-600">Human-Centered</div>
            </div>
            <div class="text-center fade-in">
              <div class="text-2xl font-bold text-gray-900 mb-2">Ethical</div>
              <div class="text-gray-600">AI Framework</div>
            </div>
          </div>
          <div class="max-w-3xl mx-auto fade-in">
            <div class="text-gray-900 text-lg mb-8">
              <div class="text-gray-400">
                <p class="typing-wrapper"><b class="text-black">Redefining digital intimacy</b> - through ethical AI and intentional architecture.</p>
              </div>
            </div>
            <div class="mb-12">
              <h3 class="text-[#1C73E4] text-2xl font-bold mb-4">The Vision</h3>
              <p class="text-gray-900 text-xl leading-relaxed">Ciphree builds infrastructure for a future where technology serves our emotional well-being rather than exploiting it. We bridge the gap between human feeling and digital interaction.</p>
            </div>
            <div class="mb-12">
              <h3 class="text-[#1C73E4] text-2xl font-bold mb-4">Safe & Human</h3>
              <p class="text-gray-900 leading-relaxed mb-4">We prioritize safety and emotional fit. Our systems are inclusive of neurodivergent experiences, creating a space where every "moment" is valid and understood.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="contact" class="py-20 bg-gray-50">
        <div class="max-w-6xl mx-auto px-6">
          <div class="text-center mb-16 fade-in">
            <h2 class="text-5xl font-bold text-[#1C73E4] mb-6">Connect With Us</h2>
            <p class="text-gray-600">Share your thoughts or request early access to the Ciphree ecosystem.</p>
          </div>
          <div class="grid md:grid-cols-2 gap-12 items-start">
            <div class="fade-in">
              <img src="https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/694431590807b62fc30f1c38/b60ab0687_image.png" alt="Contact Ciphree" class="w-full object-cover rounded-3xl max-h-[500px] shadow-lg">
            </div>
            <div class="fade-in">
              <div class="mb-8">
                <div class="grid grid-cols-2 gap-8 mb-8">
                  <div>
                    <h3 class="text-[#1C73E4] text-xl font-bold mb-2">E-mail</h3>
                    <p class="text-gray-900"><%= typeof email !== 'undefined' ? email : 'hello@ciphree.com' %></p>
                  </div>
                  <div>
                    <h3 class="text-[#1C73E4] text-xl font-bold mb-2">Follow</h3>
                    <p class="text-gray-900">@Ciphreedotcom</p>
                  </div>
                </div>
              </div>
              <form class="space-y-4" action="/contact" method="POST">
                <input name="name" class="w-full px-4 py-4 bg-white border border-gray-200 rounded-xl text-base focus:ring-2 focus:ring-[#1C73E4] outline-none" placeholder="Name" required>
                <input name="email" type="email" class="w-full px-4 py-4 bg-white border border-gray-200 rounded-xl text-base focus:ring-2 focus:ring-[#1C73E4] outline-none" placeholder="Email" required>
                <textarea name="message" class="w-full px-4 py-4 bg-white border border-gray-200 rounded-xl text-base resize-none focus:ring-2 focus:ring-[#1C73E4] outline-none" placeholder="How can we build a more emotionally intelligent future together?" rows="5" required></textarea>
                <button type="submit" class="w-full bg-[#1C73E4] hover:bg-[#1557b8] text-white py-6 text-lg rounded-full font-medium transition-all">
                  Send Message
                </button>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-gray-100 py-12 mt-20">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="flex items-center gap-2">
            <img src="https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/694431590807b62fc30f1c38/82ce8b60c_image.png" alt="Ciphree" class="w-8 h-8">
            <span class="text-gray-900 font-bold">Ciphree</span>
          </div>
          <div class="flex gap-8 text-sm text-gray-500">
            <a href="#about" class="hover:text-[#1C73E4]">Our Vision</a>
            <a href="#" class="hover:text-[#1C73E4]">Privacy</a>
            <a href="#" class="hover:text-[#1C73E4]">Ethics</a>
          </div>
          <p class="text-gray-500 text-sm">© <%= new Date().getFullYear() %> Ciphree. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </div>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          const typewriter = entry.target.querySelector('.typing-wrapper');
          if (typewriter) typewriter.classList.add('animate');
        } else {
          entry.target.classList.remove('visible');
          const typewriter = entry.target.querySelector('.typing-wrapper');
          if (typewriter) typewriter.classList.remove('animate');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    document.querySelectorAll('.accordion-toggle').forEach(button => {
      button.addEventListener('click', () => {
        const content = button.parentElement.querySelector('.faq-content');
        const icon = button.querySelector('.rotate-icon');
        document.querySelectorAll('.faq-content.open').forEach(open => {
          if (open !== content) {
            open.classList.remove('open');
            open.parentElement.querySelector('.rotate-icon').style.transform = 'rotate(0deg)';
          }
        });
        content.classList.toggle('open');
        icon.style.transform = content.classList.contains('open') ? 'rotate(45deg)' : 'rotate(0deg)';
      });
    });

   const mobileMenuBtn = document.getElementById('mobile-menu-btn');
const mobileMenu = document.getElementById('mobile-menu');

mobileMenuBtn.addEventListener('click', () => {
  mobileMenu.classList.toggle('hidden');
});

// Close menu when a link is clicked
document.querySelectorAll('#mobile-menu .nav-link').forEach(link => {
  link.addEventListener('click', () => {
    mobileMenu.classList.add('hidden');
  });
});

    window.addEventListener('scroll', () => {
      let current = '';
      document.querySelectorAll('section[id]').forEach(section => {
        if (window.scrollY >= section.offsetTop - 150) current = section.getAttribute('id');
      });
      document.querySelectorAll('.nav-link').forEach(link => {
        link.classList.remove('bg-white/20', 'bg-[#1C73E4]');
        if (link.getAttribute('href') === `#${current}`) link.classList.add('bg-white/20');
      });
    });
  </script>
</body>
</html>